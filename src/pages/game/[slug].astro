---
import GameLayout from '../../layouts/GameLayout.astro';

export function getStaticPaths() {
    return [
        { params: { slug: 'hit-the-mauss' },        props: { title: 'Hit the Mauss' } },
        { params: { slug: 'fill-the-repo' },         props: { title: 'Fill the Repo' } },
        { params: { slug: 'linux-with-weix' },       props: { title: 'Linux with Weix' } },
        { params: { slug: 'running-with-haeusler' }, props: { title: 'Running with Haeusler' } },
        { params: { slug: 'test-the-tables' },       props: { title: 'Test the Tables' } },
    ];
}

const { slug } = Astro.params;
const { title } = Astro.props;
---
<GameLayout title={title}>
    <canvas id="gamecanvas" data-slug={slug}></canvas>
    <script>
        const games = import.meta.glob('../../games/*/main.ts');
        const slug = document.getElementById('gamecanvas')?.dataset.slug;

        const loader = games[`../../games/${slug}/main.ts`];
        loader?.();
    </script>
</GameLayout>